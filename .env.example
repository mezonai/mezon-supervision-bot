# =============================================================================
# mezon-supervision-bot — environment example
# Copy to .env and fill in values.
# =============================================================================

# --- HTTP ---
PORT=3000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mezon_supervision

# --- Mezon API / bot identity ---
# Bot token from Mezon developer console
MEZON_TOKEN=
# App id from developer console (= bot user id when app is installed to clan)
SUPERVISION_BOT_ID=
# Optional: gateway if not production cloud (default: gw.mezon.ai:443 TLS) in SDK
MEZON_GATEWAY_HOST=dev-mezon.nccsoft.vn
MEZON_GATEWAY_PORT=8088
MEZON_GATEWAY_USE_SSL=true

# Comma-separated Mezon user IDs who may use *ban, *unban, *update, *rewardsetup, *welcomemsg
BOT_ADMIN_IDS=

# --- Redis ---
# Used for user balance locks and reward message cache
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Reward ---
# Max points per single Quick Menu reward (numeric string)
REWARD_MAX_AMOUNT=100000
# Max total reward amount per grantor per calendar day (sum of reward_* transactions)
REWARD_MAX_PER_DAY=5000000
# Quick Menu item name prefix; suffix is amount, e.g. reward_5000 or reward-5000
REWARD_MENU_PREFIX=reward_

# --- TypeORM ---
TYPEORM_LOGGING=true
#
# Migrations: on startup, TypeORM runs pending migrations and records each run in
# the PostgreSQL table `migrations_info` (id, timestamp, name).
